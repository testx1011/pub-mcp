{
  "name": "pub-mcp",
  "version": "0.2.2",
  "description": "MCP server for pub.dev - Enables AI assistants to access Dart/Flutter package information",
  "main": "dist/cli.js",
  "type": "module",
  "bin": {
    "pub-mcp": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/testx1011/pub-mcp.git"
  },
  "homepage": "https://github.com/testx1011/pub-mcp#readme",
  "bugs": {
    "url": "https://github.com/testx1011/pub-mcp/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/testx1011/pub-mcp"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "cli": "node dist/cli.js",
    "dev": "tsx watch src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "check": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pub.dev",
    "dart",
    "flutter",
    "package-manager",
    "ai",
    "claude",
    "openai"
  ],
  "author": "Jorge Armando Rivera <text.x1011@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "p-limit": "^3.1.0",
    "pino": "^10.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
